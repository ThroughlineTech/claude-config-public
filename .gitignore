# Backups created by install.sh
*.backup.*

# OS junk
.DS_Store
Thumbs.db

# Editor junk
*.swp
*~
.vscode/

# Local-only credentials, if you ever add a secrets file
secrets.md
.env
.env.*

# Per-machine intercom secrets. Everything under secrets/ is ignored
# except the committed template.
secrets/**
!secrets/
!secrets/.env.example

# Rendered MCP config (contains the shared secret) — never committed.
.mcp.json

# Generated by install.sh from CLAUDE.md (single source of truth is CLAUDE.md)
copilot-prompts/claude-global.instructions.md

# Generated by install.sh from commands/aliases.map — real files, not symlinks
# (one line per alias defined in aliases.map)
commands/tn.md
commands/tl.md
commands/ts.md
commands/ti.md
commands/ta.md
commands/tr.md
commands/tp.md
commands/tb.md
commands/tsh.md
commands/td.md
commands/tc.md
commands/tro.md
commands/tcl.md
commands/tch.md

# Rendered Task Scheduler XML (contains username, generated at install time)
windows/*.rendered

# Per-ticket worktrees + preview PID/meta files (created by /ticket-batch, /ticket-chain)
.worktrees/

