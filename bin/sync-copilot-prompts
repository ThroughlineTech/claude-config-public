#!/usr/bin/env bash
# sync-copilot-prompts — mechanically port commands/*.md to copilot-prompts/*.prompt.md.
#
# This is the non-interactive counterpart to the sync-claude-command.prompt.md
# Copilot prompt. It bulk-ports every canonical ticket-* and plan-* command
# into a Copilot prompt with a `mode: agent` frontmatter + the Claude body +
# Compatibility Notes footer. Command-specific Copilot adaptations (e.g.
# ticket-chain single-ticket policy, AskUserQuestion → chat prompt) are then
# applied as post-processing edits elsewhere.
#
# Run from repo root. Idempotent. Does not touch alias prompts (tn/tl/tch/...).

set -euo pipefail

ROOT="$(cd "$(dirname "$0")/.." && pwd)"
SRC_DIR="$ROOT/commands"
DST_DIR="$ROOT/copilot-prompts"

# Canonical commands we port. ticket-install is special (bootstrapper) but
# still needs a Copilot mirror, so it's included.
canonicals=(
  ticket-new ticket-investigate ticket-approve ticket-review ticket-ship
  ticket-list ticket-status ticket-defer ticket-close ticket-reopen
  ticket-promote ticket-delegate ticket-collect ticket-preview ticket-cleanup
  ticket-batch ticket-chain ticket-install plan-new plan-verify
)

# Extract a frontmatter field ($1 = field name, $2 = file).
extract_field() {
  awk -v field="$1" '
    /^---$/ { fm = !fm; if (!fm) exit; next }
    fm && $0 ~ "^"field":" {
      sub("^"field":[[:space:]]*", "")
      gsub(/^['\''"]|['\''"]$/, "")
      print
      exit
    }
  ' "$2"
}

# Extract the body (everything after the closing `---` of frontmatter).
extract_body() {
  awk '
    BEGIN { fm = 0; after = 0 }
    /^---$/ { fm++; next }
    fm >= 2 { print }
  ' "$1"
}

ported=0
for name in "${canonicals[@]}"; do
  src="$SRC_DIR/$name.md"
  dst="$DST_DIR/$name.prompt.md"

  if [[ ! -f "$src" ]]; then
    echo "  skip  $name (no source at $src)" >&2
    continue
  fi

  desc=$(extract_field description "$src")
  hint=$(extract_field argument-hint "$src")
  body=$(extract_body "$src")

  {
    echo "---"
    echo "mode: agent"
    if [[ -n "$desc" ]]; then
      # Always single-quote-wrap; descriptions contain characters (leading ", em
      # dashes) that YAML would otherwise parse as structural. Escape any embedded
      # single quote by doubling it (YAML spec).
      esc_desc=${desc//\'/\'\'}
      printf "description: '%s'\n" "$esc_desc"
    fi
    if [[ -n "$hint" ]]; then
      printf "argument-hint: '%s'\n" "$hint"
    fi
    echo "---"
    echo ""
    echo "<!-- Copilot mirror of commands/$name.md. Generated by bin/sync-copilot-prompts."
    echo "     Edit the Claude source, not this file — regenerate instead. -->"
    echo ""

    # Universal Plane MCP pre-flight block — emitted for all commands that use
    # Plane MCP tools. Excluded: ticket-install (bootstrapper, creates the config)
    # and ticket-list + ticket-cleanup (bucket-1 URL handoffs, no MCP calls).
    case "$name" in
      ticket-install|ticket-list|ticket-cleanup) ;;
      *)
        cat <<'PRE'
> **Plane MCP pre-flight (Copilot — check this before the Plane path steps below):**
>
> Scan your available tool list for at least one tool matching `mcp__plane__*`, `plane_*`, or `mcp_plane_*`.
> - **None found → STOP.** Print: "Error: Plane MCP tools are not accessible. In VS Code, open the MCP panel (View → MCP Servers), ensure the `plane` server shows as Connected, and retry. Do not fall back to creating markdown tickets." Do not continue to the Markdown path.
> - **Found → note the active prefix** (e.g. `mcp__plane__` or `plane_`) and use it for every tool call in this session.
>
> **If `.claude/plane-config.md` exists, the Markdown path is off-limits** regardless of MCP status — never silently degrade to local TKT-*.md files when the project uses Plane.

PRE
        ;;
    esac

    # Per-command Copilot policy overrides, emitted before the Claude body so
    # they read as authoritative "these take priority over what follows."
    # Sourced from copilot-prompts/sync-claude-command.prompt.md "Command-specific
    # policy overrides" section.
    case "$name" in
      ticket-chain)
        cat <<'OVR'
> **Copilot-specific override (authoritative — overrides the Claude source below):**
>
> - **Single-ticket only.** Accept exactly one ticket ID plus optional `--dry-run` or `--ship`. Do not advertise multi-ticket syntax; if extra IDs are given, warn and process only the first. For multi-ticket work, direct the user to `/ticket-batch`.
> - **Flow:** if the ticket is `Backlog` (Plane) or `open` (Markdown), investigate first. Then implement and review. If `--ship`, continue through ship steps automatically.
> - **Plan-drift check:** before implementation, re-read the ticket's Implementation Plan and compare against the current code. If the plan references renamed or removed files, stop and ask the user to re-investigate.
> - **Prowl:** conditional — send if the Prowl API key is accessible via CLAUDE.md conventions; otherwise print the final summary prominently instead.
> - **No parallel subagents.** Any subagent fan-out in the Claude source runs as a sequential loop in Copilot.

OVR
        ;;
      ticket-batch)
        cat <<'OVR'
> **Copilot-specific override (authoritative):**
>
> - **Note on /ticket-chain in Copilot:** the Copilot version of `/ticket-chain` is single-ticket only. Use `/ticket-batch` when you need to process multiple tickets together with preview infrastructure and port management. For the full multi-ticket chain experience (dependency graphs, wave execution, consolidated review), use Claude Code's `/ticket-chain`.
> - **No parallel subagents.** Run per-ticket work as a sequential loop; the Claude source's parallel fan-out is not available in Copilot.
> - **Prowl:** conditional — send if the Prowl API key is accessible via CLAUDE.md conventions; otherwise print the final summary prominently instead.

OVR
        ;;
      ticket-investigate)
        cat <<'OVR'
> **Copilot-specific override (authoritative):**
>
> - **Multi-ticket runs sequentially, not in parallel.** The Claude source fans out investigation subagents; in Copilot, loop through the IDs one at a time in one agent session.
> - **Recognized flags:** `--in-given-order`, `--order-only`, `--auto` (extended for Copilot multi-ticket use per sync-claude-command policy).
> - **Ordering output must include:** recommended order, one-line reason per ticket, and the dependency/risk signals used.
> - **Next-step suggestions:** in the ordering output, reference `/tch` as per-ticket single calls (e.g. `/tch TKT-001 --ship, then /tch TKT-002 --ship`). Never suggest the multi-ticket `/tch` form — Copilot's `/tch` is single-ticket only.

OVR
        ;;
    esac

    printf '%s\n' "$body"
    echo ""
    echo "## Compatibility Notes"
    echo ""
    echo "- **MCP tool mapping:** In VS Code Copilot, Plane MCP tools are typically exposed as \`plane_<tool_name>\` (e.g. \`plane_create_work_item\`), not \`mcp__plane__<tool_name>\` (Claude Code convention). The Plane MCP pre-flight above detects which prefix is active and uses it for the session. For explicit IDs, prefer direct identifier lookup; if unavailable, use bounded project-scoped lookup + exact match."
    echo "- **AskUserQuestion:** Copilot has no equivalent structured-question tool. When the Claude source says \"use AskUserQuestion\", ask the user in chat with a numbered or bulleted choice and wait for a reply."
    echo "- **Parallel subagents → sequential loop:** if the Claude source fans out subagents in parallel (e.g. ticket-investigate multi-ticket, ticket-batch), run them as a sequential loop in one agent session instead. Output and behavior are identical; only wall-clock differs."
    echo "- **Backend dispatch:** the \"Pre-flight: detect backend\" block is authoritative in both hosts. \`.claude/plane-config.md\` presence routes to the Plane path; otherwise the Markdown path runs."
  } > "$dst"

  ported=$((ported + 1))
  echo "  port  $name → copilot-prompts/$name.prompt.md"
done

echo ""
echo "Ported $ported canonical command(s) to Copilot prompts."

# --- Alias parity ---------------------------------------------------------
# Sync each alias's argument-hint and description with the canonical, so the
# VS Code tooltip stays accurate.
ALIAS_MAP="$SRC_DIR/aliases.map"
if [[ -f "$ALIAS_MAP" ]]; then
  echo ""
  echo "Alias parity (from commands/aliases.map):"
  alias_updated=0
  while IFS= read -r line || [[ -n "$line" ]]; do
    case "$line" in ''|\#*) continue ;; esac
    alias=$(echo "$line" | awk '{print $1}')
    target=$(echo "$line" | awk '{print $2}')
    [[ -n "$alias" && -n "$target" ]] || continue

    canonical_src="$SRC_DIR/$target.md"
    alias_dst="$DST_DIR/$alias.prompt.md"

    [[ -f "$canonical_src" && -f "$alias_dst" ]] || continue

    target_hint=$(extract_field argument-hint "$canonical_src")
    target_desc=$(extract_field description "$canonical_src")

    # Compose an alias-flavored description: "alias for /<target> — <target's description>"
    alias_desc="alias for /$target"
    [[ -n "$target_desc" ]] && alias_desc="$alias_desc — $target_desc"
    alias_desc_esc=${alias_desc//\'/\'\'}

    # Rewrite only the frontmatter; leave the delegation body untouched.
    tmp="$alias_dst.tmp"
    awk -v desc="$alias_desc_esc" -v hint="$target_hint" '
      BEGIN { fm = 0 }
      /^---$/ { fm++; print; next }
      fm == 1 && /^description:/ { printf "description: %s%s%s\n", "\x27", desc, "\x27"; next }
      fm == 1 && /^argument-hint:/ {
        if (hint != "") printf "argument-hint: %s%s%s\n", "\x27", hint, "\x27"
        next
      }
      { print }
    ' "$alias_dst" > "$tmp" && mv "$tmp" "$alias_dst"
    echo "  sync  /$alias → /$target (hint: ${target_hint:-<none>})"
    alias_updated=$((alias_updated + 1))
  done < "$ALIAS_MAP"
  echo ""
  echo "Updated $alias_updated alias prompt(s)."
fi
