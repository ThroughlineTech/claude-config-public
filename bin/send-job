#!/usr/bin/env bash
set -euo pipefail
export PATH="/c/Program Files/mosquitto:$PATH"
# shellcheck disable=SC1090
source "$HOME/.config/intercom/creds"

if [ $# -lt 3 ]; then
  echo "usage: send-job <machine> <repo> <prompt>" >&2
  exit 2
fi

MACHINE="$1"
REPO="$2"
shift 2
PROMPT="$*"

PAYLOAD=$(jq -nc --arg p "$PROMPT" '{prompt:$p, ts:now}')

exec mosquitto_pub \
  -h "$MQTT_HOST" -p "$MQTT_PORT" \
  -u "$MQTT_USER" -P "$MQTT_PASS" \
  -q 1 -t "jobs/$MACHINE/$REPO" \
  -m "$PAYLOAD"
